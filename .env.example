# ═══════════════════════════════════════════════════════════════════
# PLAYEROK BOT — конфигурация
# ═══════════════════════════════════════════════════════════════════
# 1. Скопируй файл в .env (без .example) в той же папке
# 2. Заполни все значения ниже
# 3. Запусти: python bot_handlers.py
# ═══════════════════════════════════════════════════════════════════


# ─── Telegram Bot API ──────────────────────────────────────────────
# Токен бота от @BotFather. Обязательное поле — без него бот не стартует.
BOT_TOKEN=8916831550:AAH8OQt6rJtkkpXHBvwaIy3gKr3aqXM2pd4


# ─── Владельцы системы ─────────────────────────────────────────────
# SYSTEM_OWNER_ID — главный владелец, получатель приватных уведомлений
# (логи, алёрты, ошибки). Один числовой ID.
SYSTEM_OWNER_ID=8947091063

# SYSTEM_OWNER_USERNAME — юзернейм владельца БЕЗ @ (для логов и
# сообщений вида «обратитесь к @owner»).
SYSTEM_OWNER_USERNAME=Playerok_Gifts

# EXTRA_OWNERS — доп. владельцы с такими же правами что и SYSTEM_OWNER.
# Несколько ID через запятую без пробелов: 111,222,333
EXTRA_OWNERS=


# ─── Менеджер для передачи товаров ─────────────────────────────────
# Юзернейм поддержки С @ (или t.me-ссылка) — куда продавец отправляет
# подарок при OTC-сделке. Показывается во всех текстах кнопок и
# сообщений: «Передать товар через @ваш_менеджер».
MANAGER_USERNAME=@Playerok_Gifts


# ─── Приватный админ-форум (для админских событий) ─────────────────
# chat_id Telegram-форума (число со знаком минус, типа -100).
# Получить можно отправив боту команду /id в форуме (если бот туда
# добавлен). В форуме должны быть созданы топики с такими номерами:
#   5  — Сделки: события
#   7  — Сделки: споры
#   9  — Профиты: не подтверждённые (бот рассылает кнопки [✅/✏️/🚫])
#   11 — Профиты: подтверждённые
#   13 — Выплаты: заявки
#   15 — Выплаты: история
#   17 — Юзеры: события (новый /start, блок/анбан)
#   19 — Алёрты ошибок
#   21 — Аудит админов (кто что нажал)
#   23 — Инфа (рестарты, рефреш кешей)
#   25 — Дайджесты (cron каждое утро)
# Если форум не настроен — оставь пустым, тогда все админские уведомления
# пойдут в ЛС SYSTEM_OWNER_ID.
ADMIN_FORUM_ID=-100


# ─── Публичный форум команды (для воркеров) ────────────────────────
# Сюда уходят профиты/выплаты/логи в МАСКИРОВАННОМ виде (юзернеймы
# и ссылки на NFT затёрты). Воркеры видят что профиты идут, но не
# могут восстановить контакты мамонтов.
TEAM_FORUM_ID=-1003723570122
# Номера топиков внутри TEAM_FORUM_ID. Дефолты 2/3/4 — поменяй под
# свой форум:
TEAM_FORUM_PROFITS=12
TEAM_FORUM_PAYOUTS=15
TEAM_FORUM_LOGS=18


# ─── Канал профитов (опционально) ──────────────────────────────────
# Если хочешь автопостить профиты в отдельный канал — укажи chat_id.
# Бот должен быть добавлен в канал как админ.
PROFITS_CHANNEL_ID=-1004304726091


# ─── Публичные (зашифрованные) логи (опционально) ──────────────────
# Канал для коротких маскированных событий. Если не нужен — оставь пустым.
PUBLIC_LOGS_FORUM_ID=-1004304726091


# ─── Floor-цены NFT через Portals (опционально) ────────────────────
# Если задан — бот авто-оценивает профит сделки по floor подарка
# (через portal-market.com). Если пустой — админ оценивает руками.
# Public-API работает без авторизации; auth_data нужна только для
# private endpoint (точные цены с учётом атрибутов).
PORTALS_AUTH_DATA=


# ─── HTTP-таймауты и прочее ────────────────────────────────────────
REQUEST_TIMEOUT=15
LOG_LEVEL=INFO

# Прокси для HTTP-вызовов floor/currency (если бот за NAT и Telegram
# доступен напрямую, но Portals/CoinGecko — нет). Формат socks5/http.
# FLOOR_HTTP_PROXY=socks5://user:pass@host:port
FLOOR_HTTP_PROXY=
CURRENCY_HTTP_PROXY=
